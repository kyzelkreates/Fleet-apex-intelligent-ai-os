{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output"
  },
  "include": [
    "api/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "public"
  ]
}
