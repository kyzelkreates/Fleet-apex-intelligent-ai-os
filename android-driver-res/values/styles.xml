<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#0A0A1A</item>
        <item name="colorPrimaryDark">#0A0A1A</item>
        <item name="colorAccent">#7B61FF</item>
        <item name="android:windowBackground">#0A0A1A</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#0A0A1A</item>
        <item name="colorPrimaryDark">#0A0A1A</item>
        <item name="colorAccent">#7B61FF</item>
        <item name="android:statusBarColor">#0A0A1A</item>
        <item name="android:navigationBarColor">#0A0A1A</item>
    </style>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A1A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
