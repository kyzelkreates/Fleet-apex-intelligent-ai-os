{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "*.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["*.ts"] }
    }
  ],
  "routes": [
    { "src": "/api/ai/chat",      "dest": "/chat.ts" },
    { "src": "/api/branding(.*)", "dest": "/branding.ts" },
    { "src": "/api/emergency",    "dest": "/emergency.ts" },
    { "src": "/api/hazards(.*)",  "dest": "/hazards.ts" },
    { "src": "/api/location(.*)", "dest": "/location.ts" },
    { "src": "/api/admin/seed-vault", "dest": "/branding.ts" },
    { "src": "/(.*)",             "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/sw_driver-pwa_public.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ]
}
