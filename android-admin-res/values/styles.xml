<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#050E1A</item>
        <item name="colorPrimaryDark">#050E1A</item>
        <item name="colorAccent">#00D4FF</item>
        <item name="android:windowBackground">#050E1A</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#050E1A</item>
        <item name="colorPrimaryDark">#050E1A</item>
        <item name="colorAccent">#00D4FF</item>
        <item name="android:statusBarColor">#050E1A</item>
        <item name="android:navigationBarColor">#050E1A</item>
    </style>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#050E1A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
