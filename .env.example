# Fleet Apex Intelligent AI — Environment Variables
# Copy this to .env and fill in your values

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Push Notifications (Web Push VAPID) ──────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_SERVICE_URL=https://your-push-service.com
PUSH_SERVICE_KEY=your-push-key

# ── App URLs ──────────────────────────────────────────────────────
VITE_APP_URL=https://app.fleetapex.ai
VITE_DRIVER_URL=https://driver.fleetapex.ai
VITE_API_URL=https://api.fleetapex.ai

# ── Supabase Realtime ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
